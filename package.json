{
  "name": "copilot-usage-widget",
  "version": "2.0.0",
  "description": "A frameless desktop widget that shows your GitHub Copilot premium-request usage in real time.",
  "main": "main.js",
  "author": "Serge ARADJ",
  "license": "MIT",
  "homepage": "https://github.com/orty/copilot-usage-widget",
  "repository": {
    "type": "git",
    "url": "https://github.com/orty/copilot-usage-widget.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.copilotusage.widget",
    "productName": "Copilot-Usage-Widget",
    "copyright": "Copyright © 2026 Serge ARADJ",
    "publish": null,
    "files": [
      "**/*",
      "!**/*.ts",
      "!*.md",
      "!docs/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-${version}-win-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-portable.${ext}",
      "unpackDirName": "copilot-usage-widget"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSHumanReadableCopyright": "Copyright © 2026 Serge ARADJ"
      }
    },
    "dmg": {
      "artifactName": "${productName}-${version}-macOS-${arch}.dmg"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/logo.png",
      "category": "Utility",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    }
  }
}
